VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Server-only Firebase Admin credentials for Vercel API routes that write to
# Firebase Storage. Use either FIREBASE_SERVICE_ACCOUNT_KEY as JSON/base64 JSON,
# or the split FIREBASE_CLIENT_EMAIL + FIREBASE_PRIVATE_KEY fields.
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_SERVICE_ACCOUNT_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Domain used to map usernames to synthetic auth emails ({username}@<domain>).
# Keep this stable across environments — changing it orphans existing logins.
VITE_AUTH_EMAIL_DOMAIN=brilliant-clone.local

# Dev-only: username that sees the screen-jump nav. Leave blank to disable.
# Kept out of source so no real username is committed to the repo.
VITE_DEV_USERNAME=

# Server-only OpenAI key for custom theme-pack generation.
# Do not expose this through VITE_* client variables.
OPENAI_API_KEY=
OPENAI_THEME_MODEL=gpt-4.1-mini

# Server-only Cartesia API key for future voice generation.
# Do not expose this through VITE_* client variables.
CARTESIA_API=
CARTESIA_MODEL_ID=sonic-3
CARTESIA_VERSION=2024-11-13
CARTESIA_DEFAULT_VOICE_ID=
CARTESIA_VOICE_ID_ROYAL=
CARTESIA_VOICE_ID_SPACE=
CARTESIA_VOICE_ID_DINOSAURS=
CARTESIA_VOICE_ID_ANIMALS=
CARTESIA_VOICE_ID_SPORTS=
CARTESIA_VOICE_ID_SURPRISE=
